#!/usr/bin/env bash
# pre-push hook - Validate plugin before allowing push
#
# Runs CPV remote validation via uvx (fetched from the claude-plugins-validation
# repo) — the legacy in-repo validator script was retired in commit 6058ebc
# ("ci: replace local validators with CPV uvx remote validation"), so this hook
# uses the same command as .github/workflows/validate.yml.
#
# Exit codes from cpv-remote-validate:
#   0 - All checks passed
#   1 - CRITICAL issues found (blocks push)
#   2 - MAJOR issues found (blocks push)
#   3 - MINOR issues found (non-blocking note)
#
# To install:
#   mkdir -p .git/hooks && cp git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# To bypass (NOT RECOMMENDED):
#   git push --no-verify

set -euo pipefail

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the root directory of the git repository
REPO_ROOT="$(git rev-parse --show-toplevel)"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  Pre-push Plugin Validation${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# Check what's being pushed
REMOTE="$1"
URL="$2"

echo -e "${BLUE}Pushing to:${NC} ${REMOTE} (${URL})"  # SC-P1-006: variables are safe here (echo only, no eval)
echo ""

# Check if plugin files changed in the commits being pushed
NEEDS_VALIDATION=false
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    if [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ]; then
        # Branch deletion, skip validation
        echo -e "${GREEN}Branch deletion detected. No validation needed.${NC}"
        continue
    fi

    if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
        # New branch: compare against merge-base with main/master, fall back to listing all files
        MERGE_BASE=$(git merge-base "$LOCAL_SHA" origin/main 2>/dev/null || git merge-base "$LOCAL_SHA" origin/master 2>/dev/null || true)
        if [ -n "$MERGE_BASE" ]; then
            CHANGED_FILES=$(git diff --name-only "$MERGE_BASE" "$LOCAL_SHA")
        else
            CHANGED_FILES=$(git ls-tree -r --name-only "$LOCAL_SHA")
        fi
    else
        # Existing branch, check changed files
        CHANGED_FILES=$(git diff --name-only "$REMOTE_SHA..$LOCAL_SHA" 2>/dev/null || true)
    fi

    PLUGIN_FILES_CHANGED=false
    while IFS= read -r file; do
        case "$file" in
            .claude-plugin/*|agents/*|commands/*|skills/*|hooks/*|scripts/*.py|scripts/*.sh|*.mcp.json)
                PLUGIN_FILES_CHANGED=true
                ;;
        esac
    done <<< "$CHANGED_FILES"

    if [ "$PLUGIN_FILES_CHANGED" = true ]; then
        NEEDS_VALIDATION=true
    fi
done

if [ "$NEEDS_VALIDATION" = false ]; then
    echo -e "${GREEN}No plugin files changed in any ref. Skipping validation.${NC}"
    exit 0
fi

echo -e "${BLUE}Running plugin validation...${NC}"
echo ""

cd "$REPO_ROOT"

# CPV remote validation via uvx — pinned to the same source and flags as
# .github/workflows/validate.yml so local pushes and CI agree on the verdict.
# (The pre-6058ebc local-script path was removed together with the script.)
if ! command -v uvx &> /dev/null; then
    echo -e "${RED}ERROR: uvx not found (install uv: https://docs.astral.sh/uv/)${NC}"
    echo -e "${RED}Cannot validate plugin. Push blocked.${NC}"
    exit 1
fi

set +e
uvx --from git+https://github.com/Emasoft/claude-plugins-validation \
    cpv-remote-validate plugin . --strict --verbose 2>&1
VALIDATION_EXIT_CODE=$?
set -e

echo ""

# Handle exit codes - CRITICAL and MAJOR block push
case "$VALIDATION_EXIT_CODE" in
    0)
        echo -e "${GREEN}========================================${NC}"
        echo -e "${GREEN}  PASSED: All validation checks passed${NC}"
        echo -e "${GREEN}  Push allowed.${NC}"
        echo -e "${GREEN}========================================${NC}"
        exit 0
        ;;
    1)
        echo -e "${RED}========================================${NC}"
        echo -e "${RED}  BLOCKED: CRITICAL issues found${NC}"
        echo -e "${RED}  Fix ALL issues before pushing.${NC}"
        echo -e "${RED}========================================${NC}"
        exit 1
        ;;
    2)
        echo -e "${RED}========================================${NC}"
        echo -e "${RED}  BLOCKED: MAJOR issues found${NC}"
        echo -e "${RED}  Fix ALL issues before pushing.${NC}"
        echo -e "${RED}========================================${NC}"
        exit 1
        ;;
    3)
        echo -e "${BLUE}========================================${NC}"
        echo -e "${BLUE}  NOTE: MINOR issues found (non-blocking)${NC}"
        echo -e "${BLUE}  Review and fix when possible.${NC}"
        echo -e "${GREEN}  Push allowed.${NC}"
        echo -e "${BLUE}========================================${NC}"
        exit 0
        ;;
    *)
        echo -e "${RED}========================================${NC}"
        echo -e "${RED}  ERROR: Validation failed (exit $VALIDATION_EXIT_CODE)${NC}"
        echo -e "${RED}  Please check the validation script.${NC}"
        echo -e "${RED}========================================${NC}"
        exit 1
        ;;
esac
