#!/usr/bin/env bash
# pre-push hook - Validate plugin before allowing push
#
# Auto-syncs validation scripts from claude-plugins-validation (CPV) repo,
# then runs validate_plugin.py. CRITICAL and MAJOR issues block the push.
#
# Exit codes from validate_plugin.py:
#   0 - All checks passed
#   1 - CRITICAL issues found (blocks push)
#   2 - MAJOR issues found (blocks push)
#   3 - MINOR issues found (non-blocking note)
#
# To install:
#   mkdir -p .git/hooks && cp git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# To bypass (NOT RECOMMENDED):
#   git push --no-verify

set -euo pipefail

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the root directory of the git repository
REPO_ROOT="$(git rev-parse --show-toplevel)"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  Pre-push Plugin Validation${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# Check what's being pushed
REMOTE="$1"
URL="$2"

echo -e "${BLUE}Pushing to:${NC} ${REMOTE} (${URL})"
echo ""

# Check if plugin files changed in the commits being pushed
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    if [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ]; then
        # Branch deletion, skip validation
        echo -e "${GREEN}Branch deletion detected. No validation needed.${NC}"
        continue
    fi

    if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
        # New branch, check all files
        CHANGED_FILES=$(git diff --name-only "$LOCAL_SHA" HEAD~10 2>/dev/null || git ls-tree -r --name-only "$LOCAL_SHA")
    else
        # Existing branch, check changed files
        CHANGED_FILES=$(git diff --name-only "$REMOTE_SHA..$LOCAL_SHA" 2>/dev/null || true)
    fi

    PLUGIN_FILES_CHANGED=false
    while IFS= read -r file; do
        case "$file" in
            .claude-plugin/*|agents/*|commands/*|skills/*|hooks/*|scripts/*.py|scripts/*.sh|*.mcp.json)
                PLUGIN_FILES_CHANGED=true
                ;;
        esac
    done <<< "$CHANGED_FILES"

    if [ "$PLUGIN_FILES_CHANGED" = true ]; then
        NEEDS_VALIDATION=true
    fi
done

if [ "${NEEDS_VALIDATION:-false}" = false ]; then
    echo -e "${GREEN}No plugin files changed in any ref. Skipping validation.${NC}"
    exit 0
fi

echo -e "${BLUE}Running plugin validation...${NC}"
echo ""

cd "$REPO_ROOT"

# --- Auto-sync validation scripts from CPV repo ---
CPV_REPO="Emasoft/claude-plugins-validation"
CPV_BRANCH="main"
CPV_SCRIPTS_DIR="scripts"

# List of CPV scripts to sync (validation + utilities)
CPV_FILES=(
    "cpv_validation_common.py"
    "validate_agent.py"
    "validate_command.py"
    "validate_documentation.py"
    "validate_encoding.py"
    "validate_enterprise.py"
    "validate_hook.py"
    "validate_lsp.py"
    "validate_marketplace_pipeline.py"
    "validate_marketplace.py"
    "validate_mcp.py"
    "validate_plugin.py"
    "validate_rules.py"
    "validate_scoring.py"
    "validate_security.py"
    "validate_skill_comprehensive.py"
    "validate_skill.py"
    "validate_xref.py"
    "bump_version.py"
    "check_version_consistency.py"
    "gitignore_filter.py"
    "lint_files.py"
    "setup_git_hooks.py"
    "setup_marketplace_automation.py"
    "setup_plugin_pipeline.py"
    "smart_exec.py"
    "update_marketplace_metadata.py"
)

echo -e "${BLUE}Syncing validation scripts from ${CPV_REPO}...${NC}"
SYNC_FAILED=false
if command -v gh &> /dev/null; then
    for cpv_file in "${CPV_FILES[@]}"; do
        # Download raw file from GitHub via gh api
        if gh api "repos/${CPV_REPO}/contents/${CPV_SCRIPTS_DIR}/${cpv_file}?ref=${CPV_BRANCH}" \
            --jq '.content' 2>/dev/null | base64 -d > "${REPO_ROOT}/scripts/${cpv_file}.tmp" 2>/dev/null; then
            # Only replace if download succeeded and file is non-empty
            if [ -s "${REPO_ROOT}/scripts/${cpv_file}.tmp" ]; then
                mv "${REPO_ROOT}/scripts/${cpv_file}.tmp" "${REPO_ROOT}/scripts/${cpv_file}"
            else
                rm -f "${REPO_ROOT}/scripts/${cpv_file}.tmp"
                SYNC_FAILED=true
            fi
        else
            rm -f "${REPO_ROOT}/scripts/${cpv_file}.tmp"
            SYNC_FAILED=true
        fi
    done

    if [ "$SYNC_FAILED" = true ]; then
        echo -e "${YELLOW}  Some scripts failed to sync. Using existing local copies.${NC}"
    else
        echo -e "${GREEN}  Synced ${#CPV_FILES[@]} validation scripts from ${CPV_REPO}.${NC}"
        echo -e "${YELLOW}  NOTE: CPV validation scripts updated locally. Commit them separately before next push.${NC}"
    fi
else
    echo -e "${YELLOW}  gh CLI not found. Skipping CPV sync. Using existing local copies.${NC}"
fi
echo ""
# --- End auto-sync ---
# NOTE: Downloaded scripts are used in-place. For full supply-chain integrity, pin to a specific CPV release tag.

# Check that the validator script exists
if [ ! -f "scripts/validate_plugin.py" ]; then
    echo -e "${RED}ERROR: scripts/validate_plugin.py not found${NC}"
    echo -e "${RED}Cannot validate plugin. Push blocked.${NC}"
    exit 1
fi

# Use uv with --with pyyaml (needed since most plugins lack pyproject.toml)
# Falls back to python3 if uv is not available
set +e
if command -v uv &> /dev/null; then
    uv run --with pyyaml python scripts/validate_plugin.py . --verbose 2>&1
else
    python3 scripts/validate_plugin.py . --verbose 2>&1
fi
VALIDATION_EXIT_CODE=$?
set -e

echo ""

# Handle exit codes - CRITICAL and MAJOR block push
case "$VALIDATION_EXIT_CODE" in
    0)
        echo -e "${GREEN}========================================${NC}"
        echo -e "${GREEN}  PASSED: All validation checks passed${NC}"
        echo -e "${GREEN}  Push allowed.${NC}"
        echo -e "${GREEN}========================================${NC}"
        exit 0
        ;;
    1)
        echo -e "${RED}========================================${NC}"
        echo -e "${RED}  BLOCKED: CRITICAL issues found${NC}"
        echo -e "${RED}  Fix ALL issues before pushing.${NC}"
        echo -e "${RED}========================================${NC}"
        exit 1
        ;;
    2)
        echo -e "${RED}========================================${NC}"
        echo -e "${RED}  BLOCKED: MAJOR issues found${NC}"
        echo -e "${RED}  Fix ALL issues before pushing.${NC}"
        echo -e "${RED}========================================${NC}"
        exit 1
        ;;
    3)
        echo -e "${BLUE}========================================${NC}"
        echo -e "${BLUE}  NOTE: MINOR issues found (non-blocking)${NC}"
        echo -e "${BLUE}  Review and fix when possible.${NC}"
        echo -e "${GREEN}  Push allowed.${NC}"
        echo -e "${BLUE}========================================${NC}"
        exit 0
        ;;
    *)
        echo -e "${RED}========================================${NC}"
        echo -e "${RED}  ERROR: Validation failed (exit $VALIDATION_EXIT_CODE)${NC}"
        echo -e "${RED}  Please check the validation script.${NC}"
        echo -e "${RED}========================================${NC}"
        exit 1
        ;;
esac
