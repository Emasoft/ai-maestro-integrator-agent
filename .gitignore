# Dev folders (NEVER PUBLISH - development artifacts only)
# Wildcard pattern catches all: docs_dev, scripts_dev, tests_dev, samples_dev,
# examples_dev, downloads_dev, libs_dev, builds_dev, reports_dev, etc.
# Explicit reports_dev line is required so CPV's literal-pattern checker
# recognizes the rule — it doesn't expand wildcards.
*_dev/
reports_dev/

# Testing
.coverage
htmlcov/
.pytest_cache/

# Node (used by some skills/tools)
node_modules/

# Logs and temp files
*.log
*.tmp
*.bak
*.externbak
.DS_Store
.claude/

# LLM Externalizer output
llm_externalizer_output/

# TLDR cache
.tldr/
.tldrignore
.tldr_session_*

# SERENA MCP state (local project metadata, not published)
.serena/

# git-cliff scratch — ephemeral release notes between bump and push
.git-cliff-release-notes.md

# Rechecker plugin runtime artifacts (worktree mgmt + merge-pending notifications)
.rechecker/
rck-*-merge-pending.md
